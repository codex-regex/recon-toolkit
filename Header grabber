```
try:
    response = requests.get(url, timeout=5)

    print(f"📡 Status Code : {response.status_code}")
    print(f"\n📋 Response Headers:\n")

    # Security headers to flag specifically
    security_headers = [
        "Strict-Transport-Security",
        "Content-Security-Policy",
        "X-Frame-Options",
        "X-XSS-Protection",
        "X-Content-Type-Options",
    ]

    found_security = []

    for header, value in response.headers.items():
        print(f"  {header}: {value}")
        if header in security_headers:
            found_security.append(header)

    print("\n" + "-" * 40)
    print(f"\n🛡️  Security Headers Found ({len(found_security)}/{len(security_headers)}):")

    for h in security_headers:
        if h in found_security:
            print(f"  ✅ {h}")
        else:
            print(f"  ⚠️  {h} — MISSING")

except requests.exceptions.ConnectionError:
    print(f"❌ Could not connect to {url}")
except requests.exceptions.Timeout:
    print(f"❌ Request timed out for {url}")
except Exception as e:
    print(f"❌ Error: {e}")

print("\n✅ Header grab complete.\n")
