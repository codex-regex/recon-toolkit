try:
    # Resolve hostname to IP address
    ip = socket.gethostbyname(target)
    print(f"📍 Resolved to IP: {ip}\n")
except socket.gaierror:
    print(f"❌ Could not resolve hostname: {target}")
    sys.exit(1)

open_ports = []

for port, service in COMMON_PORTS.items():
    try:
        # Create a socket and try to connect
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(1)  # Wait max 1 second per port
        result = sock.connect_ex((ip, port))

        if result == 0:
            print(f"  ✅ Port {port:<6} OPEN   — {service}")
            open_ports.append(port)
        else:
            print(f"  ❌ Port {port:<6} closed — {service}")

        sock.close()

    except Exception as e:
        print(f"  ⚠️  Port {port} error: {e}")

print("-" * 40)
print(f"\n📊 Scan complete. {len(open_ports)} open port(s) found.")
if open_ports:
    print(f"   Open ports: {open_ports}\n")
